# --- sito-mydietplan-pro (landing + API serverless Vercel) — variabili d'ambiente ---
# Configurale su Vercel (Project Settings -> Environment Variables). NON committare valori reali.

# Supabase (lato server: il service_role bypassa la RLS — TENERLO SEGRETO)
SUPABASE_URL=https://eygjcollweybbgyasnsa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__service_role_key__

# Lemon Squeezy
LEMON_SQUEEZY_WEBHOOK_SECRET=__webhook_signing_secret__
LEMON_SQUEEZY_API_KEY=__api_key_per_disdetta__

# Resend (email)
RESEND_API_KEY=__resend_api_key__
TO_EMAIL=daniele.gabrovec@gmail.com
# Mittente: usa un dominio VERIFICATO in Resend per non finire in SPAM
RESEND_FROM_EMAIL=MyDietPlan Pro <noreply@nutrizionistagabrovec.it>

# CORS: origin autorizzati a chiamare /api/cancel-subscription e /api/send (separati da virgola)
ALLOWED_ORIGINS=https://mydietplan-green.vercel.app,https://midietplan-pro.vercel.app
